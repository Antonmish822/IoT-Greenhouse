# Общие настройки
APP_NAME=Greenhouse Backend
DATABASE_URL=sqlite:///./backend/dev.db
JWT_SECRET=replace_this_with_secure_random_value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ThingsBoard
THINGSBOARD_URL=http://localhost:5010
THINGSBOARD_USERNAME=example@gmail.com
THINGSBOARD_PASSWORD=password
THINGSBOARD_LOGIN_PATH=/api/auth/login
THINGSBOARD_DEVICE_CHECK_PATH=api/device/{serial_number}