APP_NAME="Greenhouse Backend"
DATABASE_URL="sqlite:///./data/dev.db"
JWT_SECRET="super-secret-jwt-key" # CHANGE THIS IN PRODUCTION
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
FRONTEND_ALLOWED_ORIGIN="http://localhost:8000" # Comma-separated list of allowed origins
THINGSBOARD_URL="http://localhost:8080"
THINGSBOARD_TOKEN=""
THINGSBOARD_DEVICE_CHECK_PATH="api/device/{serial_number}"
THINGSBOARD_USERNAME="tenant@thingsboard.org"
THINGSBOARD_PASSWORD="tenant"
THINGSBOARD_LOGIN_PATH="/api/auth/login"
THINGSBOARD_REQUEST_TIMEOUT=10.0
THINGSBOARD_TELEMETRY_PATH="/api/plugins/telemetry/DEVICE/{device_id}/values/timeseries"
THINGSBOARD_TELEMETRY_KEYS="temperature,humidity,windowPosition,status,position"
THINGSBOARD_TELEMETRY_LIMIT=120
